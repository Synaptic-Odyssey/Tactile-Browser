{
    "manifest_version": 3,
    "name": "Tactile Browser",
    "version": "1.1",
    "description": "Converts visible webpage elements into a tactile pin-grid representation.",

    "permissions": [
        "scripting",
        "tabs",
        "activeTab"
    ],

    "background": {
        "service_worker": "background.js"
    },

    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "Tactile Browser"
    },

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],

    "host_permissions": ["<all_urls>"]
}